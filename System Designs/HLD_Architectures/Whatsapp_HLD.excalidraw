    {
      "id": "OkKzTcTycMlBuMPm-aAol",
      "type": "text",
      "x": 1126.9577101031882,
      "y": 1569.1209032413205,
      "width": 120.69989013671875,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
