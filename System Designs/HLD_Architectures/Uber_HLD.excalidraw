      "isDeleted": false,
      "boundElements": null,
      "updated": 1775680814833,
      "link": null,
      "locked": false,
      "text": "For High Availability:\n    -- Each of microservices will have multiple instances running.\n    -- they will have their own load-balancers.\n    -- We have Dynamo DB for scaling and high availablity.\n    -- Redis cluster handles freq location updates with \"Geo-Hashing\".\n-- Below setup will be cloned and split based on regions. ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For High Availability:\n    -- Each of microservices will have multiple instances running.\n    -- they will have their own load-balancers.\n    -- We have Dynamo DB for scaling and high availablity.\n    -- Redis cluster handles freq location updates with \"Geo-Hashing\".\n-- Below setup will be cloned and split based on regions. ",
