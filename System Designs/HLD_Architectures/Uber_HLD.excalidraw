    {
      "id": "uzKK71BUuSdY_FSHYKc3j",
      "type": "text",
      "x": 708.3019332014081,
      "y": 1576.3623427579687,
      "width": 488.8197021484375,
      "height": 150,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
