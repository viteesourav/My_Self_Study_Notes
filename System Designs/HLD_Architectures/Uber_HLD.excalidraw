    {
      "id": "o09-2OAgrpEmf4o3EI0YV",
      "type": "text",
      "x": 773.8143897530066,
      "y": 2062.953309680622,
      "width": 890.3594360351562,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1L",
      "roundness": null,
      "seed": 1878277758,
      "version": 793,
      "versionNonce": 141401726,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775680655784,
      "link": null,
      "locked": false,
      "text": "How do we allow high surges ?\n    -- It's possible that we have multiple instances running.\n    -- sometimes it also get's overwhellemed and crash unexpecedly.\n    -- Sol:\n        - we introduce a Queue infront of Ride Request Queue.\n        - it will add some breathing space for the overwhellemed service.\n     - Cannot be a FIFO Queue. Reason: There won;t be any logical seperation of requests.\n        - It has to be partitioned based on Regions / locations. -> beeter management.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "How do we allow high surges ?\n    -- It's possible that we have multiple instances running.\n    -- sometimes it also get's overwhellemed and crash unexpecedly.\n    -- Sol:\n        - we introduce a Queue infront of Ride Request Queue.\n        - it will add some breathing space for the overwhellemed service.\n     - Cannot be a FIFO Queue. Reason: There won;t be any logical seperation of requests.\n        - It has to be partitioned based on Regions / locations. -> beeter management.",
      "autoResize": true,
      "lineHeight": 1.25
    },
