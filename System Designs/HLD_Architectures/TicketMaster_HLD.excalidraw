      "seed": 2027763533,
      "version": 528,
      "versionNonce": 208024387,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775921781423,
      "link": null,
      "locked": false,
      "text": "Case1: you use a database Query like below to search Events in table.\n\n    Select * \n    from DB\n    where name like %term%\n\nCons: This searches the whole DB -> Very slow !!!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Case1: you use a database Query like below to search Events in table.\n\n    Select * \n    from DB\n    where name like %term%\n\nCons: This searches the whole DB -> Very slow !!!",
      "autoResize": true,
      "lineHeight": 1.25
    },
