    {
      "id": "wiBHthWcuhiko9Z5rLYbj",
      "type": "text",
      "x": 1414.4803162887824,
      "y": 2199.7775684836797,
      "width": 1037.71923828125,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b09",
      "roundness": null,
      "seed": 19472291,
      "version": 535,
      "versionNonce": 1349479779,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775919368806,
      "link": null,
      "locked": false,
      "text": "Case: If the Redis cluster goes down ?\n    - Since our DB supports ACID Properties, For that 10 min, it will hold\n    the ticket based on who locked it first.\n    - For any other user trying to access it -> It should throw error. [A Bad User Experience]\n    - A use-case or trade-off that we need to consider -> A bad user experience  + Guarntee Consistency.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Case: If the Redis cluster goes down ?\n    - Since our DB supports ACID Properties, For that 10 min, it will hold\n    the ticket based on who locked it first.\n    - For any other user trying to access it -> It should throw error. [A Bad User Experience]\n    - A use-case or trade-off that we need to consider -> A bad user experience  + Guarntee Consistency.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "KWj1_J4a88QJLFTKUjB8-",
      "type": "text",
      "x": 2327.872911852398,
      "y": 1600.6380986216955,
      "width": 643.6595458984375,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0A",
      "roundness": null,
      "seed": 1654681389,
      "version": 373,
      "versionNonce": 458895747,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775920706922,
      "link": null,
      "locked": false,
      "text": "Note: \n\nACID Property of Database means:\n\n    1. Atomicity: write either fully happens or not at all\n    2. Consistency: DB rules/constraints remain valid\n    3. Isolation: concurrent transactions don’t corrupt each other\n    4. Durability: once committed, data is persisted",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Note: \n\nACID Property of Database means:\n\n    1. Atomicity: write either fully happens or not at all\n    2. Consistency: DB rules/constraints remain valid\n    3. Isolation: concurrent transactions don’t corrupt each other\n    4. Durability: once committed, data is persisted",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "p-6yfEtRljDJP0jWqLtv2",
      "type": "text",
      "x": 547.9086319509843,
      "y": 960.0475478887048,
      "width": 685.91943359375,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0B",
