    {
      "id": "FTpPlXy7mHm1HmiGXaWS2",
      "type": "text",
      "x": 1483.62301939053,
      "y": 950.4314876317466,
      "width": 785.2194213867188,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0H",
      "roundness": null,
      "seed": 229933923,
      "version": 590,
      "versionNonce": 1956974829,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775920821674,
      "link": null,
      "locked": false,
      "text": "ElasticSearch Lookups:\n\nIt builts an inverted index that helps searching documents by terms really qucik.\n\nplayoff: [ event1, event2, event3 ]\nswift:  [event 4, event 5]\n.....\n\nit also supports geo-spatial Queries. to optimise searches.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ElasticSearch Lookups:\n\nIt builts an inverted index that helps searching documents by terms really qucik.\n\nplayoff: [ event1, event2, event3 ]\nswift:  [event 4, event 5]\n.....\n\nit also supports geo-spatial Queries. to optimise searches.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "aa8FY4BCwrxJb09Wv8Z6d",
      "type": "arrow",
      "x": 1072.3594633151738,
      "y": 1406.5436523664093,
      "width": 183.85458205529517,
      "height": 77.07707240179434,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0I",
      "roundness": {
        "type": 2
      },
      "seed": 1948542189,
      "version": 220,
      "versionNonce": 2084656109,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775920395628,
      "link": null,
      "locked": false,
      "points": [
        [
          0,
          0
        ],
        [
          183.85458205529517,
          -77.07707240179434
