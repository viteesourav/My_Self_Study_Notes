        "focus": -0.2110318208755931,
        "gap": 11.979255620675657
      },
      "endBinding": {
        "elementId": "V6R98sKmrbLGWjxnRb-uR",
        "focus": 0.0591307614593946,
        "gap": 5.492068131203663
