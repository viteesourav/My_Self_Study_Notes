      "isDeleted": false,
      "boundElements": [
        {
          "id": "gAxmG-aHz2XSru_-u5Ktx",
          "type": "arrow"
        }
      ],
      "updated": 1777140237482,
      "link": null,
      "locked": false,
      "text": "- handles all requests to \nupdate metadata of doc",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- handles all requests to \nupdate metadata of doc",
      "autoResize": true,
