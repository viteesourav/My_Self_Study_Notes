    {
      "id": "J_RXyu7Zj9CQ0PlbRcpzs",
      "type": "text",
      "x": 1563.3642622407292,
      "y": 1008.1126449192334,
      "width": 1010.5193481445312,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b01",
      "roundness": null,
      "seed": 1913366071,
      "version": 648,
      "versionNonce": 300272311,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777140195144,
      "link": null,
      "locked": false,
      "text": "Database won't be able to handle millions of users requesting Documents \n\nSol:  Kafka\n    - This adds a buffer between the Doc metadata server and the DB.\n    - Async updates.\n    - The Kafka Consumer will read all the events of updating doc -> and it async-wise update the DB. \n\n!! This is a pub-sub Design Pattern !!",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Database won't be able to handle millions of users requesting Documents \n\nSol:  Kafka\n    - This adds a buffer between the Doc metadata server and the DB.\n    - Async updates.\n    - The Kafka Consumer will read all the events of updating doc -> and it async-wise update the DB. \n\n!! This is a pub-sub Design Pattern !!",
      "autoResize": true,
      "lineHeight": 1.25
    },
